{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Bank of America Digital Lockbox ASPEC Schema",
    "type": "object",
    "properties": {
        "SpecificationIdentifier": {
            "type": "string"
        },
        "Lockboxes": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "GlobalClientIdentifier": {
                        "type": "object",
                        "properties": {
                            "FamilyGCI": {
                                "type": "string"
                            },
                            "PrimaryGCI": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "FamilyGCI",
                            "PrimaryGCI"
                        ]
                    },
                    "SiteIdentifier": {
                        "type": "string",
                        "enum": ["ATL", "BOS", "CHI", "DAL", "LAC"]
                    },
                    "LockboxNumber": {
                        "type": "string",
                        "pattern": "^[0-9]{6}$"
                    },
                    "LockboxName": {
                        "type": "string",
                        "minLength": 1
                    },
                    "LockboxStatus": {
                        "type": "string",
                        "enum": ["Active", "Closed"]
                    },
                    "DigitalIndicator": {
                        "type": "boolean"
                    },
                    "PostalCode": {
                        "type": "string",
                        "pattern": "^[0-9]{5}(-[0-9]{4})?$"
                    },
                    "AddressList": {
                        "type": "array",
                        "minItems": 1,
                        "items": {
                            "type": "object",
                            "properties": {
                                "AddressType": { "type": "string" },
                                "AddressCompanyName": { "type": "string" },
                                "AddressAttn": { "type": "string" },
                                "AddressStreet1": { "type": "string" },
                                "AddressStreet2": { "type": "string" },
                                "AddressCity": { "type": "string" },
                                "AddressState": { "type": "string" },
                                "AddressPostalCode": { "type": "string" },
                                "AddressCountry": { "type": "string" }
                            }
                        }
                    }
                },
                "if": {
                    "properties": { "DigitalIndicator": { "const": true } }
                },
                "then": {
                    "properties": {
                        "AddressList": {
                            "items": {
                                "properties": {
                                    "AddressType": { "enum": ["Mailing", "Alternate", "Lockbox"] },
                                    "AddressCompanyName": { "minLength": 1 },
                                    "AddressStreet1": { "minLength": 1 },
                                    "AddressCity": { "minLength": 1 },
                                    "AddressState": { "minLength": 2, "maxLength": 2 },
                                    "AddressPostalCode": { "pattern": "^[0-9]{5}(-[0-9]{4})?$" }
                                },
                                "required": [
                                    "AddressType",
                                    "AddressCompanyName",
                                    "AddressStreet1",
                                    "AddressCity",
                                    "AddressState",
                                    "AddressPostalCode",
                                    "AddressCountry"
                                ]
                            }
                        }
                    }
                },
                "else": {
                    "properties": {
                        "AddressList": {
                            "items": {
                                "properties": {
                                    "AddressPostalCode": {
                                        "anyOf": [
                                            { "minLength": 0, "maxLength": 0 },
                                            { "pattern": "^[0-9]{5}(-[0-9]{4})?$" }
                                        ]
                                    }
                                }
                            }
                        }
                    }
                },
                "required": [
                    "SiteIdentifier",
                    "LockboxNumber",
                    "LockboxName",
                    "LockboxStatus",
                    "DigitalIndicator",
                    "PostalCode",
                    "AddressList"
                ]
            }
        },
        "SummaryInfo": {
            "type": "object",
            "properties": {
                "ASPECDate": {
                    "type": "string",
                    "minLength": 1
                },
                "LockboxCount": {
                    "type": "integer",
                    "minimum": 1
                }
            },
            "required": [
                "ASPECDate",
                "LockboxCount"
            ]
        }
    },
    "required": [
        "SpecificationIdentifier",
        "Lockboxes",
        "SummaryInfo"
    ]
}
