{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Bank of America Digital Lockbox ASPEC Schema",
    "type": "object",
    "properties": {
        "SpecificationIdentifier": {
            "type": "string"
        },
        "Lockboxes": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "GlobalClientIdentifier": {
                        "type": "object",
                        "properties": {
                            "FamilyGCI": {
                                "type": "string"
                            },
                            "PrimaryGCI": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "FamilyGCI",
                            "PrimaryGCI"
                        ]
                    },
                    "SiteIdentifier": {
                        "type": "string",
                        "enum": ["ATL", "BOS", "CHI", "DAL", "LAC"]
                    },
                    "LockboxNumber": {
                        "type": "string",
                        "pattern": "^[0-9]{6}$"
                    },
                    "LockboxName": {
                        "type": "string",
                        "minLength": 1
                    },
                    "LockboxStatus": {
                        "type": "string",
                        "enum": ["Active", "Closed"]
                    },
                    "DigitalIndicator": {
                        "type": "boolean"
                    },
                    "PostalCode": {
                        "type": "string",
                        "pattern": "^[a-zA-Z0-9 -]{3,15}$"
                    },
                    "AddressList": {
                        "type": "array",
                        "minItems": 1,
                        "items": {
                            "type": "object",
                            "properties": {
                                "AddressType": {
                                    "type": "string",
                                    "enum": ["Mailing", "Alternate", "Lockbox"]
                                },
                                "AddressCompanyName": {
                                    "type": "string",
                                    "minLength": 1
                                },
                                "AddressAttn": {
                                    "type": "string"
                                },
                                "AddressStreet1": {
                                    "type": "string",
                                    "minLength": 1
                                },
                                "AddressStreet2": {
                                    "type": "string"
                                },
                                "AddressCity": {
                                    "type": "string",
                                    "minLength": 1
                                },
                                "AddressState": {
                                    "type": "string",
                                    "minLength": 2,
                                    "maxLength": 2
                                },
                                "AddressPostalCode": {
                                    "type": "string",
                                    "pattern": "^[a-zA-Z0-9 -]{3,15}$"
                                },
                                "AddressCountry": {
                                    "type": "string"
                                }
                            },
                            "required": [
                                "AddressType",
                                "AddressCompanyName",
                                "AddressStreet1",
                                "AddressCity",
                                "AddressState",
                                "AddressPostalCode",
                                "AddressCountry"
                            ]
                        }
                    }
                },
                "required": [
                    "SiteIdentifier",
                    "LockboxNumber",
                    "LockboxName",
                    "LockboxStatus",
                    "DigitalIndicator",
                    "PostalCode",
                    "AddressList"
                ]
            }
        },
        "SummaryInfo": {
            "type": "object",
            "properties": {
                "ASPECDate": {
                    "type": "string",
                    "minLength": 1
                },
                "LockboxCount": {
                    "type": "integer",
                    "minimum": 1
                }
            },
            "required": [
                "ASPECDate",
                "LockboxCount"
            ]
        }
    },
    "required": [
        "SpecificationIdentifier",
        "Lockboxes",
        "SummaryInfo"
    ]
}
